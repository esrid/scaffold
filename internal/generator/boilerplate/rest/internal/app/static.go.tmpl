package app

import (
	"net/http"
	"path/filepath"
	"strings"
)

func serveStatic(mux *http.ServeMux, path string, root http.FileSystem) {
	if strings.ContainsAny(path, "{}") {
		panic("serveStatic does not permit URL parameters in path.")
	}

	if path != "/" && path[len(path)-1] != '/' {
		mux.Handle("GET "+path, http.RedirectHandler(path+"/", http.StatusMovedPermanently))
		path += "/"
	}
	pathPrefix := path

	mux.HandleFunc("GET "+path, func(w http.ResponseWriter, r *http.Request) {
		ext := strings.ToLower(filepath.Ext(r.URL.Path))
		if ext != ".js" && ext != ".css" {
			http.NotFound(w, r)
			return
		}
		http.StripPrefix(strings.TrimSuffix(pathPrefix, "/"), http.FileServer(root)).ServeHTTP(w, r)
	})
}
