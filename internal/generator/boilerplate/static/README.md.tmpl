### Exemple C : Cache Redis

```go
// internal/core/ports/cache.go
type Cache interface {
    Get(ctx context.Context, key string) ([]byte, error)
    Set(ctx context.Context, key string, val []byte, ttl time.Duration) error
    Del(ctx context.Context, key string) error
}
```

```go
// internal/adapters/redis/adapter.go
import "github.com/redis/go-redis/v9"

type Adapter struct{ rdb *redis.Client }

func New(addr string) *Adapter {
    return &Adapter{rdb: redis.NewClient(&redis.Options{Addr: addr})}
}

func (a *Adapter) Get(ctx context.Context, key string) ([]byte, error) {
    return a.rdb.Get(ctx, key).Bytes()
}

func (a *Adapter) Set(ctx context.Context, key string, val []byte, ttl time.Duration) error {
    return a.rdb.Set(ctx, key, val, ttl).Err()
}
```

**Utilisation dans un service** — le service ne connaît que l'interface :

```go
// internal/core/services/product_service.go
type ProductService struct {
    store  ports.ProductStore
    cache  ports.Cache   // ← injecté, jamais "redis.Client" directement
    logger *slog.Logger
}

func (s *ProductService) Get(ctx context.Context, id string) (*domain.Product, error) {
    // 1. Check cache
    if data, err := s.cache.Get(ctx, "product:"+id); err == nil {
        var p domain.Product
        _ = json.Unmarshal(data, &p)
        return &p, nil
    }
    // 2. Fallback to DB
    p, err := s.store.Get(ctx, id)
    if err != nil {
        return nil, err
    }
    // 3. Populate cache
    if data, _ := json.Marshal(p); data != nil {
        _ = s.cache.Set(ctx, "product:"+id, data, 5*time.Minute)
    }
    return &p, nil
}
```

