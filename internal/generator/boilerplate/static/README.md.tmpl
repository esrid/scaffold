### Étape 6 : Câbler statiquement dans le Registre (`internal/app/registry.go`)
Le point final ! On assemble nos blocs statiquement dans le registre d'application :

```go
package app

// ... imports ...

type Handlers struct {
	Product *http.ProductHandler // Notre handler étendu
}

func NewRegistry(db *sql.DB, logger *slog.Logger) *Registry {
	st := store.NewStore(db)

	stores := &Stores{
		Product: st,
	}

	svcs := &Services{
		Product: services.NewProductService(stores.Product, logger),
	}

	handlers := &Handlers{
		Product: http.NewProductHandler(svcs.Product, logger),
	}

	return &Registry{Stores: stores, Services: svcs, Handlers: handlers}
}
```

Vous pouvez maintenant lancer l'application de manière ultra-propre dans votre point d'entrée principal (`main.go`) en déléguant tout le cycle de vie au runner `App` :

```go
package main

import (
	"log"
	"[[.Module]]/internal/app"
	_ "github.com/joho/godotenv/autoload"
)

func main() {
	cfg, err := app.LoadConfig()
	if err != nil {
		log.Fatalf("failed to load config: %v", err)
	}

	appInstance, err := app.NewApp(cfg)
	if err != nil {
		log.Fatalf("failed to initialize app: %v", err)
	}

	if err := appInstance.Run(); err != nil {
		log.Fatalf("app crashed: %v", err)
	}
}
```

