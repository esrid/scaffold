### Étape 5 : Créer l'adaptateur HTTP avec validation du Payload (`internal/adapters/http/product_handler.go`)
Nous créons un `ProductHandler` qui hérite du comportement CRUD générique mais ajoute une route spécifique `/products/sku/{sku}` et valide le JSON ou le formulaire envoyé :

```go
package http

import (
	"encoding/json"
	"log/slog"
	"net/http"
	"[[.Module]]/internal/core/domain"
	"[[.Module]]/internal/core/ports"
	"github.com/go-chi/chi/v5"
)

type ProductHandler struct {
	*CRUDHandler[domain.Product] // Composition : on hérite des 5 routes CRUD
	service ports.ProductService
	logger  *slog.Logger
}

func NewProductHandler(service ports.ProductService, logger *slog.Logger) *ProductHandler {
	return &ProductHandler{
		CRUDHandler: NewCRUDHandler[domain.Product](service, "Product", "", logger),
		service:     service,
		logger:      logger,
	}
}

// Enregistrement étendu des routes sur un Chi Router
func (h *ProductHandler) RegisterRoutes(r chi.Router) {
	h.CRUDHandler.RegisterRoutes(r) // Enregistre GET, LIST, POST, PUT, DELETE
	r.Get("/sku/{sku}", h.FindBySKU) // Notre route spécifique
}

// Handler de notre route spécifique
func (h *ProductHandler) FindBySKU(w http.ResponseWriter, r *http.Request) {
	sku := chi.URLParam(r, "sku") // Utilisation de chi pour extraire les paramètres
	p, err := h.service.FindBySKU(r.Context(), sku)
	if err != nil {
		respondError(w, err)
		return
	}
	respondJSON(w, http.StatusOK, p)
}
```

