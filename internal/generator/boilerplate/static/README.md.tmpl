### Exemple B : Email (AWS SES, Resend, SMTP)

```go
// internal/core/ports/mailer.go
type Mailer interface {
    Send(ctx context.Context, to, subject, htmlBody string) error
}
```

```go
// internal/adapters/resend/adapter.go
import "github.com/resend/resend-go/v2"

type Adapter struct{ client *resend.Client }

func New(apiKey string) *Adapter {
    return &Adapter{client: resend.NewClient(apiKey)}
}

func (a *Adapter) Send(ctx context.Context, to, subject, htmlBody string) error {
    _, err := a.client.Emails.Send(&resend.SendEmailRequest{
        From:    "noreply@votre-domaine.com",
        To:      []string{to},
        Subject: subject,
        Html:    htmlBody,
    })
    return err
}
