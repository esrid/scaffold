# Application Configuration
ADDR=:8080
BASE_URL=http://localhost:8080
LOG_LEVEL=info
APP_ENV=development

# Database
{{- if eq .DB "postgres"}}
DATABASE_URL=postgres://localhost/{{.AppName}}?sslmode=disable
{{- else}}
DATABASE_URL=file:app.db?_journal_mode=WAL&_foreign_keys=on
{{- end}}

# Security (must be at least 32 bytes in production)
SECRET_KEY=
