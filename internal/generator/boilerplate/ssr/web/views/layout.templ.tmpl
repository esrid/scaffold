package views

import "{{.Module}}/internal/flash"

templ Layout(title string) {
	<!DOCTYPE html>
	<html lang="en">
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>
				if title != "" {
					{ title } — App
				} else {
					App
				}
			</title>
			<link rel="stylesheet" href="/static/app.css"/>
			<script src="https://unpkg.com/htmx.org@1.9.12"></script>
		</head>
		<body>
			<nav class="navbar">
				<a href="/" class="navbar-brand">App</a>
			</nav>
			<main class="container">
				if msg := flash.From(ctx); msg != nil {
					<div class={ "flash", "flash-" + string(msg.Kind) } role="status">{ msg.Text }</div>
				}
				{ children... }
			</main>
		</body>
	</html>
}
