// mountAt mounts h at prefix so BOTH "prefix" (no trailing slash — the
// standard REST convention) and "prefix/..." reach it directly.
// http.StripPrefix alone only covers the trailing-slash subtree; the bare
// prefix would 307-redirect first. This rewrites the path in-process and
// re-dispatches through mux instead — no HTTP redirect, no extra round trip.
func mountAt(mux *http.ServeMux, prefix string, h http.Handler) {
	stripped := http.StripPrefix(prefix, h)
	mux.Handle(prefix+"/", stripped)
	mux.HandleFunc(prefix, func(w http.ResponseWriter, r *http.Request) {
		r.URL.Path += "/"
		mux.ServeHTTP(w, r)
	})
}
