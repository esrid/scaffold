package app

import (
	"context"
	"errors"
	"fmt"
	"log/slog"
	"net"
	"net/http"
	"os"
	"time"

	httpAdapter "{{.Module}}/internal/adapters/http"
	"{{.Module}}/internal/adapters/store"
	"{{.Module}}/web"
	"{{.Module}}/web/views"
	"github.com/go-chi/chi/v5"
	"github.com/go-chi/chi/v5/middleware"
	{{- if eq .DB "postgres"}}
	"github.com/jackc/pgx/v5/pgxpool"
	{{- else}}
	"database/sql"
	{{- end}}
	{{- if .GRPC}}
	"google.golang.org/grpc"
	"google.golang.org/grpc/health"
	healthpb "google.golang.org/grpc/health/grpc_health_v1"
	"google.golang.org/grpc/reflection"
	{{- end}}
)

type App struct {
	cfg      Config
	{{- if eq .DB "postgres"}}
	pool     *pgxpool.Pool
	{{- else}}
	db       *sql.DB
	{{- end}}
	logger   *slog.Logger
	registry *Registry
	{{- if .GRPC}}
	grpcServer *grpc.Server
	{{- end}}
}

func NewApp(ctx context.Context, cfg Config) (*App, error) {
	logger := buildLogger(cfg.LogLevel, cfg.Env)

	{{- if eq .DB "postgres"}}
	connCtx, cancel := context.WithTimeout(ctx, 10*time.Second)
	defer cancel()
	pool, err := store.Open(connCtx, cfg.DatabaseURL)
	if err != nil {
		return nil, fmt.Errorf("open store: %w", err)
	}
	{{- else}}
	db, err := store.Open(cfg.DatabaseURL)
	if err != nil {
		return nil, err
	}
	{{- end}}

	return &App{
		cfg:    cfg,
		{{- if eq .DB "postgres"}}
		pool:   pool,
		{{- else}}
		db:     db,
		{{- end}}
		logger:   logger,
		{{- if eq .DB "postgres"}}
		registry: NewRegistry(pool, logger),
		{{- else}}
		registry: NewRegistry(db, logger),
		{{- end}}
	}, nil
}

func (a *App) Run(ctx context.Context) error {
	{{- if .GRPC}}
	grpcLn, err := net.Listen("tcp", a.cfg.GRPCAddr)
	if err != nil {
		return fmt.Errorf("failed to listen for gRPC on %s: %w", a.cfg.GRPCAddr, err)
	}
	a.grpcServer = grpc.NewServer()
	healthSrv := health.NewServer()
	healthpb.RegisterHealthServer(a.grpcServer, healthSrv)
	// scaffold: register grpc handlers here
	if a.cfg.Env != "production" {
		reflection.Register(a.grpcServer)
	}
	a.logger.Info("gRPC Server listening", "addr", a.cfg.GRPCAddr)
	go func() {
		if err := a.grpcServer.Serve(grpcLn); err != nil {
			a.logger.Error("gRPC server crashed", "err", err)
		}
	}()
	{{- end}}

	ln, err := net.Listen("tcp", a.cfg.Addr)
	if err != nil {
		return fmt.Errorf("failed to listen on %s: %w", a.cfg.Addr, err)
	}

	srv := &http.Server{
		Handler:           a.buildRouter(),
		ReadHeaderTimeout: 5 * time.Second,
		ReadTimeout:       5 * time.Second,
		WriteTimeout:      65 * time.Second,
		IdleTimeout:       120 * time.Second,
		BaseContext: func(net.Listener) context.Context {
			return ctx
		},
	}

	a.logger.Info("HTTP Server listening", "addr", ln.Addr().String(), "log_level", a.cfg.LogLevel)
	go func() {
		if err := srv.Serve(ln); err != nil && !errors.Is(err, http.ErrServerClosed) {
			a.logger.Error("server crashed", "err", err)
		}
	}()

	<-ctx.Done()
	return a.shutdown(srv)
}

func (a *App) buildRouter() *chi.Mux {
	r := chi.NewRouter()
	a.mountMiddlewares(r)
	a.mountRoutes(r)
	return r
}

func (a *App) mountMiddlewares(r *chi.Mux) {
	r.Use(middleware.RequestID)
	r.Use(middleware.CleanPath)
	r.Use(httpAdapter.CORS())
	r.Use(httpAdapter.StructuredLogger(a.logger))
	r.Use(httpAdapter.StructuredRecoverer(a.logger))
	r.Use(middleware.Timeout(60 * time.Second))
}

func (a *App) mountRoutes(r *chi.Mux) {
	r.Get("/health", a.healthHandler)
	r.Handle("/static/*", http.FileServerFS(web.StaticFS))
	r.Get("/", func(w http.ResponseWriter, r *http.Request) {
		w.Header().Set("Content-Type", "text/html; charset=utf-8")
		if err := views.Home().Render(r.Context(), w); err != nil {
			a.logger.Error("render home", "err", err)
			http.Error(w, "Internal Server Error", http.StatusInternalServerError)
		}
	})
	// scaffold:routes:start
	// scaffold:routes:end
}

func (a *App) healthHandler(w http.ResponseWriter, r *http.Request) {
	w.Header().Set("Content-Type", "application/json")
	{{- if eq .DB "postgres"}}
	if err := a.pool.Ping(r.Context()); err != nil {
	{{- else}}
	if err := a.db.PingContext(r.Context()); err != nil {
	{{- end}}
		a.logger.Error("database health check failed", "err", err)
		w.WriteHeader(http.StatusInternalServerError)
		_, _ = w.Write([]byte(`{"status":"unhealthy","database":"disconnected"}`))
		return
	}
	w.WriteHeader(http.StatusOK)
	_, _ = w.Write([]byte(`{"status":"healthy","database":"connected"}`))
}

func (a *App) shutdown(srv *http.Server) error {
	a.logger.Info("shutting down gracefully...")
	{{- if .GRPC}}
	if a.grpcServer != nil {
		stopped := make(chan struct{})
		go func() { a.grpcServer.GracefulStop(); close(stopped) }()
		select {
		case <-stopped:
		case <-time.After(15 * time.Second):
			a.grpcServer.Stop()
		}
	}
	{{- end}}
	shutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)
	defer cancel()
	if err := srv.Shutdown(shutdownCtx); err != nil {
		a.logger.Error("failed to shutdown HTTP server", "err", err)
	}
	{{- if eq .DB "postgres"}}
	a.pool.Close()
	{{- else}}
	if err := a.db.Close(); err != nil {
		a.logger.Error("failed to close database connection", "err", err)
	}
	{{- end}}
	a.logger.Info("shutdown complete. Goodbye!")
	return nil
}

func buildLogger(logLevel, env string) *slog.Logger {
	var level slog.Level
	switch logLevel {
	case "debug":
		level = slog.LevelDebug
	case "warn":
		level = slog.LevelWarn
	case "error":
		level = slog.LevelError
	default:
		level = slog.LevelInfo
	}
	opts := &slog.HandlerOptions{Level: level}
	var handler slog.Handler
	if env == "production" {
		handler = slog.NewJSONHandler(os.Stdout, opts)
	} else {
		handler = slog.NewTextHandler(os.Stdout, opts)
	}
	logger := slog.New(handler)
	slog.SetDefault(logger)
	return logger
}
